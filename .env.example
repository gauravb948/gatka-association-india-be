DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gatka"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000

# Cloudflare R2 (S3-compatible) for image uploads
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-bucket-name"
R2_PUBLIC_BASE_URL="https://<your-public-domain-or-r2-public-url>"
R2_REGION="auto"

# Rate limiting (per IP). Set TRUST_PROXY=1 when behind a reverse proxy.
TRUST_PROXY="0"
RATE_LIMIT_API_WINDOW_MS="900000"
RATE_LIMIT_API_MAX="300"
RATE_LIMIT_AUTH_WINDOW_MS="900000"
RATE_LIMIT_AUTH_MAX="30"
RATE_LIMIT_UPLOAD_WINDOW_MS="3600000"
RATE_LIMIT_UPLOAD_MAX="60"
